{
  "name": "notion-time-tracker",
  "private": true,
  "version": "0.1.0",
  "description": "Minimalist desktop time tracker that syncs with Notion Work Sessions.",
  "main": "dist-electron/main.js",
  "author": "vinceo1",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.json && vite build",
    "preview": "vite preview",
    "pack:mac": "npm run build && electron-builder --mac --arm64",
    "pack:mac:intel": "npm run build && electron-builder --mac --x64",
    "pack:win": "npm run build && electron-builder --win",
    "pack:all": "npm run build && electron-builder -mw",
    "icons": "node scripts/build-icons.mjs",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@notionhq/client": "^2.2.15",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "electron-store": "^8.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.4.49",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6"
  },
  "build": {
    "appId": "com.ecomwizards.notion-time-tracker",
    "productName": "Notion Time Tracker",
    "files": [
      "dist",
      "dist-electron"
    ],
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "build/icon.icns",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
